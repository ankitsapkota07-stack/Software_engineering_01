doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= (expert.full_name || expert.username) + " Expert Profile"
    link(rel="stylesheet", href="/styles.css")

  body
    - var page = 'experts'
    include partials/header.pug

    main.page-content
      .profile-page
        .profile-container
          .profile-card
            .profile-top
              .profile-left
                if expert.profile_image
                  img.profile-avatar-image(src=expert.profile_image alt=expert.username)
                else
                  .profile-avatar
                    = expert.username ? expert.username.charAt(0).toUpperCase() : "E"

              .profile-right
                h1.profile-name= expert.full_name || expert.username
                p.profile-location= expert.location || "Unknown location"

                .profile-role-badge
                  span.role-pill.expert Alteration Expert

                .profile-meta
                  .meta-item
                    span.meta-label Username
                    span.meta-value= expert.username
                  .meta-item
                    span.meta-label Rating
                    span.meta-value ⭐ #{Number(expert.rating || 0).toFixed(1)}
                  .meta-item
                    span.meta-label Member Since
                    span.meta-value= expert.member_since || "N/A"
                  .meta-item
                    span.meta-label Role
                    span.meta-value Expert

                .profile-actions
                  a.btn.btn-outline(href="/experts") ← Back to Experts

          .profile-main-grid
            aside.profile-sidebar
              .info-card
                h3.card-heading Skills
                p= expert.skills || "No skills added yet."

              .info-card
                h3.card-heading Services Offered
                p= expert.service_description || "No service description added yet."

            main.profile-content
              .content-card
                h2.section-title About This Expert
                p.about-text= expert.bio || "This expert has not added a bio yet."

              if currentUser && currentUser.role === 'community'
                .content-card
                  h2.section-title Send Alteration Request
                  p.request-card-text Describe the repair, resizing, or alteration help you need.
                  form(action=`/experts/${expert.id}/request` method="POST")
                    textarea(name="message" placeholder="Example: I have a jacket with a broken zip and need it repaired." required)
                    button.btn.btn-primary(type="submit") Send Alteration Request

              else if !currentUser
                .content-card
                  h2.section-title Need Alteration Help?
                  p.request-card-text Log in as a community user to send a request to this expert.
                  a.btn.btn-primary(href="/login") Login to Continue

    include partials/footer.pug
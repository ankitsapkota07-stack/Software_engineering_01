doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Circular Fashion
    //- Link CSS
    link(rel="stylesheet", href="styles.css")

  body

    //- Header / Navigation
    header.site-header
      .container
        h1.logo Circular Fashion
        nav.nav
          ul
            li
              a(href="#about") About
            li
              a(href="#services") Services
            li
              a(href="#contact") Contact

    //- Hero Section
section.hero
  .container
    h2 Re-make & Mend
    p
      | Circular fashion aims to reduce waste and protect the environment by keeping clothes in use for as long as possible. Instead of throwing garments away, this approach focuses on repairing, reusing, recycling, and upcycling clothing.
      |
      | By extending the life of garments, circular fashion helps reduce textile waste, conserve natural resources, and lower pollution caused by fast fashion. It also encourages people to make more responsible and sustainable fashion choices.
      |
      | Circular fashion supports a sustainable future where clothing is valued, reused, and kept in circulation rather than ending up in landfills.
    .hero-buttons
      a.btn.primary(href="#services") Book a Repair

    //- About Section
    section#about.about
      .container
        h2 Why Circular Fashion?
        p
          | Circular fashion focuses on extending the life of garments through repair, reuse,
          | and upcycling—reducing waste and supporting a more sustainable future.

    //- Services Section
    section#services.services
      .container
        h2 Our Services
        .service-grid
          .service-card
            h3 Repair
            p Fix tears, replace zippers, and restore worn garments.

          .service-card
            h3 Upcycle
            p Transform old clothes into refreshed, personalized pieces.

          .service-card
            h3 Alterations
            p Adjust fit and style so you can keep wearing what you love.

    //- Call to Action
    section.cta
      .container
        h2 Keep Fashion in Circulation
        p Start your circular journey today.
        a.btn.primary(href="#contact") Get Started

    //- Footer
    footer#contact.site-footer
      .container
        p © 2026 Circular Fashion. All rights reserved.
        p Email: info@circularfashion.co.uk

    //- Link JavaScript
    script(src="script.js")
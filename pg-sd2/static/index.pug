doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title Circular Fashion
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/styles.css")

  body

    // HEADER
    header.site-header
      .header-flex
        h1.logo Circular Fashion

        nav.nav
          ul
            li: a(href="#home" class="active") Home
            li: a(href="#about") About
            li: a(href="#services") Services
            li: a(href="#process") How It Works
            li: a(href="#contact") Contact

        a.login-btn(href="/login") Login

    // HERO
    section#home.hero
      .section-content
        h2 Re-make & Mend
        p Give your clothes a second life. Repair, refresh and reinvent the pieces you love.
        .hero-buttons
          a.btn.primary(href="#") Book a Repair
          a.btn.secondary(href="#") Learn More
          
    // ABOUT
    section#about.about
      .section-content
        h2 Why Circular Fashion?
        p.about-text
          | Circular fashion reduces waste by keeping clothing in use for as long as possible.
          | Instead of throwing garments away, we repair, reuse and upcycle them.

    // SERVICES
    section#services.services
      .section-content
        h2 Our Services

        .service-grid
          .service-card
            h3 Repair
            p Fix tears, replace zips, and restore garments.

          .service-card
            h3 Upcycle
            p Transform old clothes into refreshed pieces.

          .service-card
            h3 Alterations
            p Adjust fit and style perfectly.

    // PROCESS
    section#process.process
      .section-content
        h2 How It Works

        .steps
          .step
            h3 1. Book
            p Choose your service

          .step
            h3 2. Send or Visit
            p Bring or mail your clothing

          .step
            h3 3. Enjoy
            p Receive your refreshed item

    // CTA
    section.cta
      .section-content
        h2 Keep Fashion in Circulation
        p Start your journey today
        a.btn.primary(href="#") Get Started

    // FOOTER
    footer#contact.site-footer
      .section-content
        p © 2026 Circular Fashion
        p Email: info@circularfashion.co.uk
        p Repair • Upcycle • Alterations

    script(src="/script.js")
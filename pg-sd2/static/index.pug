doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="description" content="Circular Fashion clothing repair, alterations and upcycling services.")
    title Circular Fashion
    link(rel="stylesheet", href="styles.css")

  body
    // Header
    header.site-flex
      .container
        h1.logo Circular Fashion
        nav.nav
          ul
            li: a(href="#home" class="active") Home
            li: a(href="#about") About
            li: a(href="#services") Services
            li: a(href="#process") How It Works
            li: a(href="#contact") Contact
            li: a.login-btn(href="/login") Login

    // Hero
    section#home.hero
      .section-content
        h2 Re-make & Mend
        p
          | Give your clothes a second life. Repair, refresh, and reinvent the pieces you love.
          | Wear longer. Waste less.
        .hero-buttons
          a.btn.primary(href="/login") Book a Repair
          a.btn.secondary(href="#about") Learn More

    // About
    section#about.about
    .container.about-container
      .about-text
        h2 Why Circular Fashion?

        p
          | Circular fashion is a sustainable approach that keeps clothing in use for as long as possible. Instead of discarding garments, we focus on repairing, reusing, and upcycling them to extend their life and reduce waste.

        p
          | This approach helps protect the environment while allowing you to keep and enjoy the clothes you love.

        p
          | Choosing circular fashion comes with many benefits:

        ul.about-list
          li 🌍 Reduces textile waste and keeps clothes out of landfills
          li ♻️ Promotes reuse, repair, and recycling of garments
          li 💷 Saves money by extending the life of your wardrobe
          li ✂️ Encourages creativity through upcycling and redesign
          li 🌱 Reduces carbon emissions and environmental impact
          li 🤝 Supports ethical and sustainable fashion practices

        p
          | By embracing circular fashion, you are contributing to a more responsible and sustainable future for the planet while still expressing your personal style.

      .about-image
        img(src="https://images.unsplash.com/photo-1521335629791-ce4aec67dd47?auto=format&fit=crop&w=800&q=60", alt="Sustainable fashion")

    section#services.services
      .section-content
        h2 Our Services

        .service-grid
          .service-card
            h3 Repair
            p Fix tears, replace zips, and restore garments.

          .service-card
            h3 Upcycle
            p Transform old clothes into refreshed pieces.

          .service-card
            h3 Alterations
            p Adjust fit and style perfectly.

    section#process.process
      .section-content
        h2 How It Works

        .steps
          .step
            h3 1. Book
            p Choose your service

          .step
            h3 2. Send or Visit
            p Bring or mail your clothing

          .step
            h3 3. Enjoy
            p Receive your refreshed item

    section.cta
      .section-content
        h2 Keep Fashion in Circulation
        p Start your journey today
        a.btn.primary(href="/login") Get Started

    footer#contact.site-footer
      .section-content
        p © 2026 Circular Fashion
        p Email: info@circularfashion.co.uk

    script(src="/script.js")
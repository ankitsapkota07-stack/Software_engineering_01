doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= item.title
    link(rel="stylesheet", href="/styles.css")

  body
    - var page = 'items'
    include partials/header.pug

    .container
      a.back-link(href="/items") ← Back to Items

    .item-container
      .item-card
        if item.image_url
          img.item-detail-image(src=item.image_url alt=item.title)
        else
          .item-placeholder No Image Available

        h1= item.title

        .item-meta
          span.badge #{item.category_name || "Uncategorised"}
          span.status #{item.availability_status || "Available"}

        .item-info
          p
            strong Owner:
            |  #{item.username || "Unknown"}

          p
            strong Size:
            |  #{item.size || "Not specified"}

          p
            strong City:
            |  #{item.city || "Not specified"}

          p
            strong Condition:
            |  #{item.condition || "Not specified"}

        .item-description
          h3 Description
          p= item.description || "No description provided."

        .item-tags
          h3 Tags
          if tags && tags.length
            ul
              each tag in tags
                li.tag= tag.name
          else
            p No tags added for this item.

        //- Logic to allow community members to request an item they don't own
        if currentUser && currentUser.role === 'community' && currentUser.id !== item.user_id
          .content-card(style="margin-top: 20px;")
            h2.section-title Request This Item
            form(action=`/items/${item.id}/request` method="POST")
              textarea(name="message" placeholder="Write a short message to request this item" required)
              button.btn.btn-primary(type="submit") Send Request

    include partials/footer.pug
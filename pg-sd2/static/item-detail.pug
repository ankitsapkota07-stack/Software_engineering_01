doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= item.title
    link(rel="stylesheet", href="/styles.css")

  body
    - var page = 'items'
    include partials/header.pug

    .container.item-detail-page
      .item-detail-topbar
        a.back-link(href="/items") ← Back to Items

      .item-detail-layout
        .item-detail-left
          .item-gallery-card
            if item.image_url
              .item-image-viewer
                img.item-detail-image#itemPreviewImage(src=item.image_url alt=item.title)
                button.view-full-btn#openImageModal(type="button") View Full Image
            else
              .item-placeholder No Image Available

        .item-detail-right
          .item-summary-card
            .item-summary-header
              h1.item-detail-title= item.title
              .item-meta
                span.badge #{item.category_name || "Uncategorised"}
                span.status #{item.availability_status || "Available"}

            .item-info-grid
              .info-pill
                span.info-label Owner
                a.owner-link(href=`/users/${item.user_id}`)= item.username || "Unknown"

              .info-pill
                span.info-label Size
                span.info-value= item.size || "Not specified"

              .info-pill
                span.info-label City
                span.info-value= item.city || "Not specified"

              .info-pill
                span.info-label Condition
                span.info-value= item.condition || "Not specified"

            .item-description-card
              h3 Description
              p= item.description || "No description provided."

            .item-tags
              h3 Tags
              if tags && tags.length
                ul
                  each tag in tags
                    li.tag= tag.name
              else
                p No tags added for this item.

            if currentUser && currentUser.role === 'community' && currentUser.id !== item.user_id
              .request-card
                h2.section-title Request This Item
                p.request-card-text Send a message to the owner to request this item.
                form(action=`/items/${item.id}/request` method="POST")
                  textarea(name="message" placeholder="Write a short message to request this item" required)
                  button.btn.btn-primary(type="submit") Send Request

    if item.image_url
      .image-modal#imageModal
        button.image-modal-close#closeImageModal(type="button") ×
        img.image-modal-content(src=item.image_url alt=item.title)

    include partials/footer.pug

    if item.image_url
      script.
        document.addEventListener("DOMContentLoaded", function () {
          const openBtn = document.getElementById("openImageModal");
          const closeBtn = document.getElementById("closeImageModal");
          const modal = document.getElementById("imageModal");
          const previewImage = document.getElementById("itemPreviewImage");

          if (!openBtn || !closeBtn || !modal || !previewImage) return;

          function openModal() {
            modal.classList.add("active");
            document.body.style.overflow = "hidden";
          }

          function closeModal() {
            modal.classList.remove("active");
            document.body.style.overflow = "";
          }

          openBtn.addEventListener("click", openModal);
          previewImage.addEventListener("click", openModal);
          closeBtn.addEventListener("click", closeModal);

          modal.addEventListener("click", function (e) {
            if (e.target === modal) closeModal();
          });

          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") closeModal();
          });
        });
doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Available Items
    link(rel="stylesheet", href="/styles.css")

  body
    - var page = 'items'
    include partials/header.pug

    section.items-hero
      .container
        .items-hero-content
          .items-hero-text
            span.hero-tag Community Listings
            h1 Explore Available Items
            p
              | Discover clothing and fashion items shared by the community.
              | Browse listings, view details, and support circular fashion.

          .items-hero-actions
            a.btn.outline(href="/") ← Back to Home
            if currentUser && currentUser.role === 'community'
              a.btn.primary(href="/items/new") + Add New Item

    section.items-section
      .container
        .items-toolbar
          form.items-search-form(action="/items" method="GET" autocomplete="off")
            .search-input-wrap
              input#itemSearch.search-input(
                type="text"
                name="q"
                placeholder="Search by title, category, owner, city, condition..."
                value=searchQuery || ""
              )
              button.btn.btn-primary(type="submit") Search
              ul#searchSuggestions.search-suggestions

          if searchQuery
            .search-result-note
              p
                | Showing results for 
                strong "#{searchQuery}"
              a.btn.btn-outline(href="/items") Clear Search

        if items && items.length
          .items-summary
            p
              strong #{items.length}
              |  item#{items.length === 1 ? '' : 's'} found

          .items-grid.advanced-items-grid
            each item in items
              .item-listing-card
                if item.image_url
                  img.item-card-image(src=item.image_url alt=item.title)
                else
                  .item-placeholder No Image

                .item-card-body
                  .item-card-top
                    h2.item-card-title= item.title
                    span.item-status-badge= item.availability_status || "Available"

                  p.item-card-category= item.category_name || "Uncategorised"

                  .item-card-meta
                    p
                      strong Owner:
                      |  #{item.username || "Unknown"}
                    p
                      strong Condition:
                      |  #{item.condition || "Not specified"}
                    p
                      strong City:
                      |  #{item.city || "Not specified"}

                  .item-card-actions
                    a.btn-view(href=`/items/${item.id}`) View Details
                    if item.user_id
                      a.btn-outline(href=`/users/${item.user_id}`) View Owner
        else
          .empty-state-box
            h2 No matching items found
            p Try another keyword like jacket, denim, dress, repair, or owner name.
            a.btn.btn-outline(href="/items") Show All Items

    section.section-reuse-banner
      .container
        .reuse-banner-content
          h2 Choose to Reuse. Choose to Inspire.
          p
            | Every item you give a second life helps reduce waste and supports a stronger,
            | more compassionate community.

    include partials/footer.pug

    script.
      document.addEventListener("DOMContentLoaded", function () {
        const input = document.getElementById("itemSearch");
        const suggestionBox = document.getElementById("searchSuggestions");

        if (!input || !suggestionBox) return;

        let debounceTimer;

        input.addEventListener("input", function () {
          const value = input.value.trim();

          clearTimeout(debounceTimer);

          if (!value) {
            suggestionBox.innerHTML = "";
            suggestionBox.style.display = "none";
            return;
          }

          debounceTimer = setTimeout(async () => {
            try {
              const res = await fetch(`/items/suggestions?q=${encodeURIComponent(value)}`);
              const suggestions = await res.json();

              suggestionBox.innerHTML = "";

              if (!suggestions.length) {
                suggestionBox.style.display = "none";
                return;
              }

              suggestions.forEach((text) => {
                const li = document.createElement("li");
                li.textContent = text;
                li.className = "search-suggestion-item";

                li.addEventListener("click", function () {
                  input.value = text;
                  suggestionBox.innerHTML = "";
                  suggestionBox.style.display = "none";
                  input.form.submit();
                });

                suggestionBox.appendChild(li);
              });

              suggestionBox.style.display = "block";
            } catch (err) {
              console.error(err);
              suggestionBox.style.display = "none";
            }
          }, 200);
        });

        document.addEventListener("click", function (e) {
          if (!suggestionBox.contains(e.target) && e.target !== input) {
            suggestionBox.style.display = "none";
          }
        });
      });